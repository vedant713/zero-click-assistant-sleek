{
  "name": "zero-click-assistant",
  "version": "1.0.0",
  "main": "main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "build:renderer": "cd renderer && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prebuild": "npm run lint",
    "postinstall": "electron-builder install-app-deps",
    "package": "npm run build:renderer && electron-builder --win --publish never",
    "release": "npm run build:renderer && electron-builder --win --publish always"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "active-win": "^8.0.0",
    "dotenv": "^17.2.3",
    "electron": "^32.0.0",
    "framer-motion": "^11.18.2",
    "path-scurry": "^2.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.2.0",
    "supertest": "^6.3.0",
    "vite": "^7.1.10",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.zeroclick.assistant",
    "productName": "Zero-Click Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "main/**/*",
      "shared/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    }
  }
}
